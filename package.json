{
  "name": "trackon-api",
  "version": "1.0.1",
  "scripts": {
  "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
  "build": "tsc",
  "start": "ts-node src/index.ts",
  "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
},
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "*",
    "cors": "*",
    "dotenv": "*",
    "express": "*",
    "express-rate-limit": "*",
    "express-validator": "*",
    "helmet": "*",
    "jsonwebtoken": "*",
    "prisma": "*",
    "@prisma/client": "*",
    "typescript": "*",
    "ts-node": "*"
  },
  "devDependencies": {
    "@types/bcryptjs": "*",
    "@types/cors": "*",
    "@types/express": "*",
    "@types/jsonwebtoken": "*",
    "@types/node": "*",
    "nodemon": "*"
  }
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now())

  alerts    Alert[]
}

model Shipment {
  id          String         @id @default(cuid())
  trackingCode String        @unique
  origin      String
  destination String
  status      ShipmentStatus @default(PENDING)
  weight      Float
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  vehicle     Vehicle?       @relation(fields: [vehicleId], references: [id])
  vehicleId   String?
  route       Route?         @relation(fields: [routeId], references: [id])
  routeId     String?
  alerts      Alert[]
}

model Vehicle {
  id        String        @id @default(cuid())
  plate     String        @unique
  model     String
  status    VehicleStatus @default(AVAILABLE)
  createdAt DateTime      @default(now())

  shipments Shipment[]
  routes    Route[]
}

model Route {
  id        String      @id @default(cuid())
  name      String
  origin    String
  destination String
  status    RouteStatus @default(ACTIVE)
  createdAt DateTime    @default(now())

  shipments Shipment[]
  vehicle   Vehicle?    @relation(fields: [vehicleId], references: [id])
  vehicleId String?
}

model Alert {
  id        String      @id @default(cuid())
  message   String
  type      AlertType
  read      Boolean     @default(false)
  createdAt DateTime    @default(now())

  shipment  Shipment?   @relation(fields: [shipmentId], references: [id])
  shipmentId String?
  user      User?       @relation(fields: [userId], references: [id])
  userId    String?
}

// --- Enums ---

enum Role {
  ADMIN
  OPERATOR
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum VehicleStatus {
  AVAILABLE
  IN_ROUTE
  MAINTENANCE
}

enum RouteStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AlertType {
  INFO
  WARNING
  ERROR
}